{
  "name": "medchain",
  "version": "1.0.0",
  "description": "MedChain EHR Blockchain - Monorepo",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "npm install --prefix ehr-blockchain/backend",
    "install-backend": "cd ehr-blockchain/backend && npm install",
    "start": "cd ehr-blockchain/backend && npm start",
    "dev": "cd ehr-blockchain/backend && npm run dev",
    "build": "npm install --prefix ehr-blockchain/backend"
  }
}
